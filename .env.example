# Rust API
# Local Docker Postgres (optional — `docker compose up -d postgres`)
# DATABASE_URL=postgres://frx:frx@localhost:5434/frx_shield
# Render (remote) — append ?sslmode=require if not present
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
API_HOST=0.0.0.0
API_PORT=8080
RUST_LOG=info,frx_api=debug
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRY_HOURS=168
SUI_MODE=mock
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_GRAPHQL_URL=https://graphql.testnet.sui.io/graphql
CHAIN_RUNNER_URL=http://localhost:8090
CHAIN_RUNNER_PORT=8090
FRX_SHIELD_PACKAGE_ID=0xb3054f645771e07202ef6b88fcd53b23249ee44492e00e8c4ef8998b1c6214e9
FRX_WALLET_PACKAGE_ID=
# Server agent wallet — signs on-chain agent_withdraw (generate: cd apps/chain-runner && npm run generate-agent-key)
FRX_AGENT_ADDRESS=
FRX_AGENT_PRIVATE_KEY=
DEEPBOOK_ENV=testnet
DEEPBOOK_POOL_KEY=SUI_USDC
PRICE_DATA_PATH=data/sui_usd_daily.csv
DEMO_RUNNER_ENABLED=true
DEMO_SCENARIO_INTERVAL_SECS=45
DEMO_SCENARIOS_PATH=data/demo_scenarios.json
AI_ENGINE_URL=http://localhost:8001

# Python AI Engine
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
LLM_PROVIDER=ollama
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_FRX_WALLET_PACKAGE_ID=
NEXT_PUBLIC_FRX_AGENT_ADDRESS=
NEXT_PUBLIC_SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# --- Production (Railway / Vercel) ---
# See docs/DEPLOYMENT.md — API reads PORT or API_PORT; chain-runner reads PORT or CHAIN_RUNNER_PORT
# Dashboard NEXT_PUBLIC_* vars are build-time on Vercel / Docker
